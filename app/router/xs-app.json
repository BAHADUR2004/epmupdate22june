{
  "welcomeFile": "/purchase/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/purchase/(.*)$",
      "target": "/$1",
      "localDir": "resources",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/purchasing/(.*)$",
      "target": "/purchasing/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa"
    }
  ]
}