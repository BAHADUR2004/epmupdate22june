{
  "name": "epm-complete",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2.8.0",
    "@sap/cds": "^9.9.1"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9",
    "@ui5/cli": "^4.0.57",
    "cds-plugin-ui5": "^0.17.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-purchase": "cds watch --open purchase/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "hana"
      },
      "auth": {
        "kind": "dummy"
      }
    },
    "build": {
      "target": "gen",
      "tasks": [
        {
          "for": "hana",
          "src": "db"
        },
        {
          "for": "nodejs",
          "src": "srv"
        }
      ]
    }
  },
  "private": true,
  "sapux": [
    "app/purchase"
  ]
}
